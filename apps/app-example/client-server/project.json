{
    "name": "client-server",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/app-example/client-server/src",
    "projectType": "application",
    "targets": {
        "test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "vitest run apps/app-example/client-server/"
            }
        },
        "build": {
            "executor": "@nx/js:tsc",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/apps/app-example/client-server",
                "main": "apps/app-example/client-server/src/server.ts",
                "tsConfig": "apps/app-example/client-server/tsconfig.app.json",
                "assets": []
            }
        },
        "serve": {
            "continuous": true,
            "executor": "@nx/js:node",
            "dependsOn": ["build"],
            "options": {
                "buildTarget": "client-server:build",
                "runBuildTargetDependencies": false
            }
        }
    },
    "tags": ["framework:express"]
}
