{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "defaultBase": "main",
    "namedInputs": {
        "default": ["{projectRoot}/**/*", "sharedGlobals"],
        "production": [
            "default",
            "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
            "!{projectRoot}/tsconfig.spec.json",
            "!{projectRoot}/.eslintrc.json",
            "!{projectRoot}/eslint.config.js"
        ],
        "sharedGlobals": []
    },
    "targetDefaults": {
        "@nx/js:tsc": {
            "cache": true,
            "dependsOn": [
                "architecture:validate-complete",
                "validate-no-file-import-cycles",
                "^build"
            ],
            "inputs": ["default", "^default"]
        },
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["production", "^production"],
            "cache": true
        },
        "test": {
            "cache": true,
            "inputs": ["default", "^default"]
        },
        "lint": {
            "inputs": [
                "default",
                "{workspaceRoot}/eslint.config.mjs",
                "{workspaceRoot}/architecture/dependencies.json"
            ],
            "cache": true,
            "options": {
                "quiet": true
            }
        },
        "@angular/build:application": {
            "dependsOn": [
                "architecture:validate-complete",
                "validate-no-file-import-cycles",
                "^build"
            ]
        },
        "validate-code": {
            "inputs": ["default", "{workspaceRoot}/webpieces.config.json"]
        },
        "validate-ts-in-src": {
            "inputs": ["default", "{workspaceRoot}/webpieces.config.json"]
        }
    },
    "plugins": [
        {
            "plugin": "@nx/eslint/plugin",
            "options": {
                "targetName": "lint"
            }
        },
        {
            "plugin": "@webpieces/nx-webpieces-rules",
            "options": {
                "_bootstrapNote": "TEMPORARY: architectureUnchanged + validatePackageJson are disabled to bootstrap the new graph model. The currently-published plugin builds the graph from build.dependsOn (now removed), so it cannot validate this commit. Re-enable (delete this options block) in the follow-up PR after bumping to the new published plugin version.",
                "workspace": {
                    "validations": {
                        "architectureUnchanged": false,
                        "validatePackageJson": false
                    }
                }
            }
        }
    ]
}
