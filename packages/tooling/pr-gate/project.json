{
    "name": "pr-gate",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/tooling/pr-gate/src",
    "projectType": "library",
    "targets": {
        "test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "vitest run packages/tooling/pr-gate/"
            }
        },
        "build": {
            "executor": "@nx/js:tsc",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/packages/tooling/pr-gate",
                "main": "packages/tooling/pr-gate/src/index.ts",
                "tsConfig": "packages/tooling/pr-gate/tsconfig.lib.json",
                "assets": ["packages/tooling/pr-gate/package.json"]
            }
        }
    },
    "tags": ["type:tooling", "framework:node", "role:lib"]
}
