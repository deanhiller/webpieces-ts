{
    "name": "@webpieces/pr-gate",
    "version": "0.0.0-dev",
    "description": "Gated PR system: 3-point squash-merge, merge validation gate, and red/yellow/green PR dashboard. Standalone scripts, no Nx dependency required.",
    "type": "commonjs",
    "main": "./src/index.js",
    "bin": {
        "wp-finish-upsert-pr": "./src/scripts/git-finishUpsertPr.js",
        "wp-start-upsert-pr": "./src/scripts/wp-start-upsert-pr.js",
        "wp-start-update": "./src/scripts/wp-start-update.js",
        "wp-finish-update": "./src/scripts/wp-finish-update.js"
    },
    "files": [
        "src/**/*"
    ],
    "author": "Dean Hiller",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/deanhiller/webpieces-ts.git",
        "directory": "packages/tooling/pr-gate"
    },
    "dependencies": {
        "@webpieces/rules-config": "workspace:*",
        "@webpieces/core-context": "workspace:*",
        "@webpieces/core-util": "workspace:*",
        "@inversifyjs/binding-decorators": "1.1.5",
        "inversify": "7.10.4",
        "reflect-metadata": "0.2.2"
    },
    "publishConfig": {
        "access": "public"
    }
}
