{
    "name": "webpieces-rules",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/tooling/webpieces-rules/src",
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "@nx/js:tsc",
            "outputs": ["{options.outputPath}"],
            "dependsOn": [
                "^build",
                "code-rules:build",
                "ai-hook-rules:build",
                "eslint-rules:build"
            ],
            "options": {
                "outputPath": "dist/packages/tooling/webpieces-rules",
                "main": "packages/tooling/webpieces-rules/src/index.ts",
                "tsConfig": "packages/tooling/webpieces-rules/tsconfig.lib.json",
                "assets": [
                    "packages/tooling/webpieces-rules/package.json",
                    "packages/tooling/webpieces-rules/README.md",
                    "packages/tooling/webpieces-rules/config",
                    "packages/tooling/webpieces-rules/bin",
                    "packages/tooling/webpieces-rules/patterns",
                    "packages/tooling/webpieces-rules/templates"
                ]
            }
        }
    },
    "tags": ["type:tooling"]
}
