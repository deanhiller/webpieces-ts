{
    "name": "@webpieces/ai-hook-rules",
    "version": "0.0.0-dev",
    "description": "Pluggable write-time validation framework for AI coding agents (@webpieces/ai-hook-rules). Claude Code PreToolUse + openclaw before_tool_call adapters share one rule engine.",
    "type": "commonjs",
    "main": "./src/index.js",
    "bin": {
        "wp-ai-rules-hook": "./bin/wp-ai-rules-hook.js",
        "wp-ai-guards-hook": "./bin/wp-ai-guards-hook.js",
        "wp-install-ai-hooks": "./bin/wp-install-ai-hooks.js",
        "wp-upgrade-shim": "./bin/wp-upgrade-shim.js"
    },
    "exports": {
        ".": "./src/index.js",
        "./package.json": "./package.json",
        "./claude-code-rules": "./src/adapters/rules-hook.js",
        "./claude-code-guards": "./src/adapters/guards-hook.js",
        "./openclaw-plugin": "./src/adapters/openclaw-plugin.js"
    },
    "files": [
        "src/**/*",
        "bin/**/*",
        "templates/**/*",
        "openclaw.plugin.json",
        "README.md"
    ],
    "author": "Dean Hiller",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/deanhiller/webpieces-ts.git",
        "directory": "packages/tooling/ai-hook-rules"
    },
    "dependencies": {
        "@webpieces/rules-config": "workspace:*"
    },
    "publishConfig": {
        "access": "public"
    }
}
