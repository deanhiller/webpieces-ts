{
    "name": "config",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/tooling/config/src",
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "@nx/js:tsc",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/packages/tooling/config",
                "main": "packages/tooling/config/src/index.ts",
                "tsConfig": "packages/tooling/config/tsconfig.lib.json",
                "assets": [
                    "packages/tooling/config/package.json",
                    "packages/tooling/config/README.md"
                ]
            }
        }
    },
    "tags": ["type:tooling"]
}
