{
    "name": "@webpieces/wp-logging",
    "version": "0.0.0-dev",
    "description": "Pluggable logging interface for WebPieces - works in browser and Node.js (plug in bunyan, winston, pino, etc.)",
    "type": "commonjs",
    "main": "./src/index.js",
    "types": "./src/index.d.ts",
    "exports": {
        ".": {
            "types": "./src/index.d.ts",
            "default": "./src/index.js"
        }
    },
    "keywords": [
        "webpieces",
        "logging",
        "logger"
    ],
    "author": "Dean Hiller",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/deanhiller/webpieces-ts.git",
        "directory": "packages/core/wp-logging"
    },
    "publishConfig": {
        "access": "public"
    }
}
