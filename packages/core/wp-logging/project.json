{
    "name": "wp-logging",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/core/wp-logging/src",
    "projectType": "library",
    "targets": {
        "test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "vitest run packages/core/wp-logging/"
            }
        },
        "build": {
            "executor": "@nx/js:tsc",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/packages/core/wp-logging",
                "main": "packages/core/wp-logging/src/index.ts",
                "tsConfig": "packages/core/wp-logging/tsconfig.lib.json",
                "assets": [
                    "packages/core/wp-logging/package.json",
                    "packages/core/wp-logging/README.md"
                ]
            }
        }
    },
    "tags": ["type:util", "framework:all", "role:lib"]
}
