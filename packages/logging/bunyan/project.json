                "tsConfig": "packages/logging/bunyan/tsconfig.lib.json",
                "assets": [
                    "packages/logging/bunyan/package.json",
                    "packages/logging/bunyan/README.md"
                ]
            }
        }
    },
    "tags": ["framework:node", "role:lib"]
