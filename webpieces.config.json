    "hookGuards": {
        "branch-creation-guard": {
            "mode": "ON_NO_SUBBRANCHES",
            "subBranchNaming": "feature/<ticket>/<short-description>",
            "ignoreModifiedUntilEpoch": 0
        },
        "pr-creation-guard": {
            "mode": "ON",
            "ignoreModifiedUntilEpoch": 0
        },
        "merge-in-progress-guard": {
            "mode": "ON",
            "ignoreModifiedUntilEpoch": 0
        },
        "pr-merge-cleanup": {
            "mode": "ON",
            "ignoreModifiedUntilEpoch": 0
        },
        "redirect-how-to-merge-main": {
            "mode": "ON",
            "ignoreModifiedUntilEpoch": 0
        },
        "feature-branch-guard": {
            "mode": "ON",
            "branchNamingConvention": "{whoami}/{featurename}",
            "hangTimeoutMinutes": 5,
            "ignoreModifiedUntilEpoch": 0
        }
    },
    "commands": {
        "pr-gate": {
            "mode": "ON",
            "buildCommandWhy": "--base is the FORK POINT via $(git merge-base origin/main HEAD), NOT origin/main: basing on origin/main marks projects from other people's already-merged PRs as 'affected' (your branch still has their pre-merge versions), wasting rebuilds. The fork point scopes affected to only your branch's work. The $(...) resolves because the gate runs with shell:true.",
            "buildCommand": "pnpm nx affected --target=ci --base=$(git merge-base origin/main HEAD)",
            "gatesWhy": "warningColor (REQUIRED on every gate) = the dashboard color shown WHEN a gate's patterns match a changed file (green is implicit when nothing matches; warningColor is purely visual and never blocks the PR — only the build gate can). disabled:true gates are kept-in-file examples (JSON has no comments) other projects flip to false and tune; they are skipped on this repo.",
            "gates": [
                {
                    "name": "API Changed",
                    "patterns": [
                        "libraries/apis/**",
                        "**/*Api.ts"
                    ],
                    "warningColor": "yellow"
                },
                {
                    "name": "Config Files Changed",
                    "patterns": [
                        "**/package.json",
                        "**/tsconfig*.json",
                        "nx.json",
                        "**/*.config.*"
                    ],
                    "warningColor": "yellow"
                },
                {
                    "name": "Dependency Graph Changed",
                    "patterns": [
                        "architecture/dependencies.json"
                    ],
                    "warningColor": "yellow"
                },
                {
                    "name": "Claude / Rules Changed",
                    "patterns": [
                        "**/CLAUDE.md",
                        "**/claude.*.md",
                        ".claude/**",
                        "webpieces.config.json"
                    ],
                    "warningColor": "yellow"
                },
                {
                    "name": "Package.json Changed",
                    "patterns": [
                        "**/package.json"
                    ],
                    "warningColor": "yellow",
                    "disabled": true
                },
                {
                    "name": "Other API Files Changed",
                    "patterns": [
                        "**/*Dto.ts"
                    ],
                    "warningColor": "yellow",
                    "disabled": true
                },
                {
                    "name": "Authentication Changed",
                    "patterns": [
                        "**/authentication.ts"
                    ],
                    "warningColor": "yellow",
                    "disabled": true
                },
                {
                    "name": "DB Schema Changed",
                    "patterns": [
                        "**/schema.prisma"
                    ],
                    "warningColor": "red",
                    "disabled": true
                },
                {
                    "name": "Migration Files",
                    "patterns": [
                        "**/migrations/**"
                    ],
                    "warningColor": "red",
                    "disabled": true
                },
                {
                    "name": "Firestore Schema Changed",
                    "patterns": [
                        "**/firestore*.ts"
                    ],
                    "warningColor": "yellow",
                    "disabled": true
                }
            ]
        },
        "upsertPr": "pnpm wp-start-upsert-pr",
        "mergeComplete": "pnpm wp-finish-upsert-pr"
    },
    "excludePaths": {
        "rules": [
            "repositories/**"
        ],
        "guards": [
            "repositories/**"
        ]
    },
    "match-rules": [
        {
            "mode": "NEW_AND_MODIFIED_CODE",
            "ignoreModifiedUntilEpoch": 0,
            "name": "no-fetch",
            "patterns": [
                "(?<![.\\w])fetch\\s*\\(",
                "\\baxios\\b",
                "\\bXMLHttpRequest\\b",
                "\\bnew\\s+Request\\s*\\(",
                "from\\s+['\"](node-fetch|got|undici)['\"]"
            ],
            "mainMessage": "Raw HTTP (fetch/axios/XMLHttpRequest/…) bypasses contract-first development — the client and server stop sharing the same API contract/types. Generate a type-safe client from the contract instead:",
            "options": [
                "PREFERRED: generate a client from the API you want to call — import { createApiClient, ClientConfig } from '@webpieces/http-client'; const client = createApiClient(SomeApi, new ClientConfig('https://host')); await client.someMethod(req);",
                "Reuse an existing API contract already defined in your repo (under libraries/apis/**) and generate its client the same way.",
                "For a truly external service, create a NEW API contract (a decorated abstract class) AND a NEW implementation that calls fetch behind that contract, under an allowlisted dir (libraries/apis-external/**). The contract stays the shared surface; fetch is an impl detail."
            ],
            "disableAllowed": true,
            "allowedPaths": [
                "packages/http/http-client/**",
                "packages/cloud/cloudtasks-client/**",
                "libraries/apis-external/**",
                "libraries/apis/external/**"
            ]
        },
        {
            "mode": "NEW_AND_MODIFIED_CODE",
            "ignoreModifiedUntilEpoch": 0,
            "name": "no-global-providesingleton-in-packages",
            "patterns": [
                "@provideSingleton\\s*\\(",
                "@provideSingletonAs\\s*\\("
            ],
            "mainMessage": "Framework code in packages/** must use @provideFrameworkSingleton (a SEPARATE DI registry) so a client's buildProviderModule() never scoops up webpieces framework classes. Plain @provideSingleton is for apps/client code only. (Turn ON once the repo consumes a @webpieces release whose DI-graph analyzer understands provideFrameworkSingleton.)",
            "options": [
                "In a packages/** framework class, use @provideFrameworkSingleton() (self-bind) or @provideFrameworkSingletonAs(TOKEN) from @webpieces/core-context.",
                "WebpiecesRouter loads buildFrameworkModule() + buildProviderModule(); any embeddable WebpiecesRouteCreator user must also load buildFrameworkModule() to resolve framework filters."
            ],
            "disableAllowed": true,
            "allowedPaths": [
                "apps/**",
                "libraries/**",
                "packages/tooling/**",
                "packages/core/core-context/src/provide.ts"
            ]
        }
    ],
    "rulesDir": []
}
