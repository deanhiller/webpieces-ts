{
    "rules": {
        "max-method-lines": {
            "limit": 80,
            "mode": "NEW_AND_MODIFIED_METHODS",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "max-file-lines": {
            "limit": 902,
            "mode": "NEW_AND_MODIFIED_FILES",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "require-return-type": {
            "mode": "NEW_AND_MODIFIED_METHODS",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "no-inline-type-literals": {
            "mode": "NEW_AND_MODIFIED_METHODS",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "no-any-unknown": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": true,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "no-implicit-any": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": true,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "prisma-validate-dtos": {
            "mode": "MODIFIED_CLASS",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 0
        },
        "prisma-converter": {
            "mode": "NEW_AND_MODIFIED_METHODS",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 0
        },
        "no-destructure": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "no-unmanaged-exceptions": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": true,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "catch-error-pattern": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": true,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "throw-cause-required": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "angular-no-direct-api-in-resolver": {
            "mode": "OFF",
            "disableAllowed": true,
            "ignoreModifiedUntilEpoch": 0
        },
        "no-symbol-di-tokens": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": true,
            "ignoreModifiedUntilEpoch": 1771931925,
            "allowedPaths": [
                "libraries/apis/**",
                "packages/http/http-api/**"
            ]
        },
        "no-file-import-cycles": {
            "mode": "RUN_EVERY_TIME",
            "ignoreTypeOnly": false,
            "ignoreModifiedUntilEpoch": 0
        },
        "runtime-architecture": {
            "mode": "RUN_EVERY_TIME",
            "servicePaths": [
                "apps/*"
            ],
            "apiProjectPaths": [
                "apps/example-apis"
            ],
            "allowedCycles": [],
            "ignoreModifiedUntilEpoch": 0
        },
        "no-js-files": {
            "mode": "NEW_AND_MODIFIED_FILES",
            "allowedPaths": [],
            "ignoreModifiedUntilEpoch": 0
        },
        "validate-ts-in-src": {
            "mode": "NEW_AND_MODIFIED_FILES",
            "ignoreModifiedUntilEpoch": 1771931925,
            "allowedRootFiles": [
                "jest.setup.ts"
            ],
            "excludePaths": [
                "node_modules",
                "dist",
                ".nx",
                ".git",
                "**/*.d.ts",
                "**/jest.config.ts",
                "**/codegen.ts"
            ]
        },
        "nx-wiring": {
            "mode": "RUN_EVERY_TIME",
            "ignoreModifiedUntilEpoch": 0
        }
    },
    "hookGuards": {
        "branch-creation-guard": {
            "mode": "ON_NO_SUBBRANCHES",
            "subBranchNaming": "feature/<ticket>/<short-description>",
            "ignoreModifiedUntilEpoch": 0
        },
        "pr-creation-guard": {
            "mode": "ON",
            "ignoreModifiedUntilEpoch": 0
        },
        "merge-in-progress-guard": {
            "mode": "ON",
            "ignoreModifiedUntilEpoch": 0
        },
        "pr-merge-cleanup": {
            "mode": "ON",
            "ignoreModifiedUntilEpoch": 0
        },
        "redirect-how-to-merge-main": {
            "mode": "ON",
            "ignoreModifiedUntilEpoch": 0
        },
        "feature-branch-guard": {
            "mode": "ON",
            "branchNamingConvention": "{whoami}/{featurename}",
            "hangTimeoutMinutes": 5,
            "ignoreModifiedUntilEpoch": 0
        }
    },
    "commands": {
        "pr-gate": {
            "mode": "ON",
            "buildCommandWhy": "--base is the FORK POINT via $(git merge-base origin/main HEAD), NOT origin/main: basing on origin/main marks projects from other people's already-merged PRs as 'affected' (your branch still has their pre-merge versions), wasting rebuilds. The fork point scopes affected to only your branch's work. The $(...) resolves because the gate runs with shell:true.",
            "buildCommand": "pnpm nx affected --target=ci --base=$(git merge-base origin/main HEAD)",
            "gatesWhy": "warningColor (REQUIRED on every gate) = the dashboard color shown WHEN a gate's patterns match a changed file (green is implicit when nothing matches; warningColor is purely visual and never blocks the PR — only the build gate can). disabled:true gates are kept-in-file examples (JSON has no comments) other projects flip to false and tune; they are skipped on this repo.",
            "gates": [
                {
                    "name": "API Changed",
                    "patterns": [
                        "libraries/apis/**",
                        "**/*Api.ts"
                    ],
                    "warningColor": "yellow"
                },
                {
                    "name": "Config Files Changed",
                    "patterns": [
                        "**/package.json",
                        "**/tsconfig*.json",
                        "nx.json",
                        "**/*.config.*"
                    ],
                    "warningColor": "yellow"
                },
                {
                    "name": "Dependency Graph Changed",
                    "patterns": [
                        "architecture/dependencies.json"
                    ],
                    "warningColor": "yellow"
                },
                {
                    "name": "Claude / Rules Changed",
                    "patterns": [
                        "**/CLAUDE.md",
                        "**/claude.*.md",
                        ".claude/**",
                        "webpieces.config.json"
                    ],
                    "warningColor": "yellow"
                },
                {
                    "name": "Package.json Changed",
                    "patterns": [
                        "**/package.json"
                    ],
                    "warningColor": "yellow",
                    "disabled": true
                },
                {
                    "name": "Other API Files Changed",
                    "patterns": [
                        "**/*Dto.ts"
                    ],
                    "warningColor": "yellow",
                    "disabled": true
                },
                {
                    "name": "Authentication Changed",
                    "patterns": [
                        "**/authentication.ts"
                    ],
                    "warningColor": "yellow",
                    "disabled": true
                },
                {
                    "name": "DB Schema Changed",
                    "patterns": [
                        "**/schema.prisma"
                    ],
                    "warningColor": "red",
                    "disabled": true
                },
                {
                    "name": "Migration Files",
                    "patterns": [
                        "**/migrations/**"
                    ],
                    "warningColor": "red",
                    "disabled": true
                },
                {
                    "name": "Firestore Schema Changed",
                    "patterns": [
                        "**/firestore*.ts"
                    ],
                    "warningColor": "yellow",
                    "disabled": true
                }
            ]
        },
        "upsertPr": "pnpm wp-start-upsert-pr",
        "mergeComplete": "pnpm wp-finish-upsert-pr"
    },
    "excludePaths": {
        "rules": [
            "repositories/**"
        ],
        "guards": [
            "repositories/**"
        ]
    },
    "rulesDir": []
}
