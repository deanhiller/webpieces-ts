{
    "rules": {
        "max-method-lines": {
            "limit": 80,
            "mode": "NEW_AND_MODIFIED_METHODS",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "max-file-lines": {
            "limit": 902,
            "mode": "MODIFIED_FILES",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "require-return-type": {
            "mode": "NEW_AND_MODIFIED_METHODS",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "no-inline-type-literals": {
            "mode": "NEW_AND_MODIFIED_METHODS",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "no-any-unknown": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": true,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "no-implicit-any": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": true,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "prisma-validate-dtos": {
            "mode": "MODIFIED_CLASS",
            "disableAllowed": false
        },
        "prisma-converter": {
            "mode": "NEW_AND_MODIFIED_METHODS",
            "disableAllowed": false
        },
        "no-destructure": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "no-unmanaged-exceptions": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": true,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "catch-error-pattern": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": true,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "throw-cause-required": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": false,
            "ignoreModifiedUntilEpoch": 1771931925
        },
        "angular-no-direct-api-in-resolver": {
            "mode": "OFF",
            "disableAllowed": true
        },
        "no-symbol-di-tokens": {
            "mode": "MODIFIED_CODE",
            "disableAllowed": true,
            "ignoreModifiedUntilEpoch": 1771931925,
            "allowedPaths": ["libraries/apis/**", "packages/http/http-api/**"]
        },
        "no-shell-substitution": {
            "mode": "OFF"
        },
        "branch-creation-guard": {
            "mode": "ON",
            "subBranchNaming": "feature/<ticket>/<short-description>"
        },
        "pr-creation-guard": {
            "mode": "ON"
        },
        "merge-in-progress-guard": {
            "mode": "ON"
        },
        "pr-merge-cleanup": {
            "mode": "ON"
        },
        "no-direct-main-update": {
            "mode": "ON"
        },
        "no-edit-on-main": {
            "mode": "ON",
            "branchNamingConvention": "{whoami}/{featurename}"
        },
        "no-file-import-cycles": {
            "mode": "ON",
            "ignoreTypeOnly": false
        },
        "runtime-architecture": {
            "mode": "ON",
            "servicePaths": ["apps/*"],
            "apiProjectPaths": ["apps/example-apis"],
            "allowedCycles": []
        },
        "no-js-files": {
            "mode": "ON",
            "allowedPaths": []
        },
        "validate-ts-in-src": {
            "mode": "MODIFIED_FILES",
            "ignoreModifiedUntilEpoch": 1771931925,
            "allowedRootFiles": ["jest.setup.ts"],
            "excludePaths": [
                "node_modules", "dist", ".nx", ".git",
                "**/*.d.ts", "**/jest.config.ts", "**/codegen.ts"
            ]
        }
    },
    "rulesDir": [],
    "pr-gate": {
        "mode": "ON",
        "buildCommand": "pnpm nx affected --target=ci --base=origin/main",
        "gates": [
            { "name": "API Changed", "patterns": ["libraries/apis/**", "**/*Api.ts"], "severity": "warn" },
            { "name": "Config Files Changed", "patterns": ["**/package.json", "**/tsconfig*.json", "nx.json", "**/*.config.*"], "severity": "warn" },
            { "name": "Dependency Graph Changed", "patterns": ["architecture/dependencies.json"], "severity": "warn" },
            { "name": "Claude / Rules Changed", "patterns": ["**/CLAUDE.md", "**/claude.*.md", ".claude/**", "webpieces.config.json"], "severity": "warn" }
        ]
    }
}
